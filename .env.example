MCP_ENDPOINT=https://api.transit.ls8h.com/mcp
HF_HOME=/path/to/huggingface
XDG_CACHE_HOME=/path/to/cache
PIP_CACHE_DIR=/path/to/pip-cache
HF_TOKEN=
FUNCTIONGEMMA_NORMALIZE_JA=1
TRANSIT_MCP_TIMEOUT=15
TRANSIT_MCP_RETRIES=2
TRANSIT_MCP_CACHE_TTL=30
TRANSIT_RATE_LIMIT_REQUESTS=30
TRANSIT_RATE_LIMIT_WINDOW=60
TRANSIT_AUDIT_LOG=1
# Queries are hashed by default. Enable raw query storage only with an explicit policy.
TRANSIT_LOG_USER_QUERY=0
TRANSIT_LOG_RAW_LOCATION=0
# Short operational trial logs. Queries are opt-in and coordinates are always redacted.
TRANSIT_BEHAVIOR_LOG=0
TRANSIT_BEHAVIOR_LOG_USER_QUERY=0
TRANSIT_BEHAVIOR_LOG_ANSWER=1
TRANSIT_BEHAVIOR_LOG_RETENTION_DAYS=45
TRANSIT_BEHAVIOR_LOG_DIR=artifacts/behavior_logs
